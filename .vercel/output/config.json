{
  "version": 3,
  "routes": [
    {
      "src": "/api/trpc/(.*)",
      "dest": "/api/trpc/trpc"
    },
    {
      "src": "/api/oauth/callback",
      "dest": "/api/oauth/callback"
    },
    {
      "src": "/api/oauth/google/init",
      "dest": "/api/oauth/google/init"
    },
    {
      "src": "/api/oauth/google/callback",
      "dest": "/api/oauth/google/callback"
    },
    {
      "src": "/api/oauth/google/status",
      "dest": "/api/oauth/google/status"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}