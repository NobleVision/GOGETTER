# GO-GETTER OS Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION (Required)
# =============================================================================
# PostgreSQL connection string
# Example: postgresql://user:password@host:port/database
DATABASE_URL=

# =============================================================================
# SECURITY CONFIGURATION (Required)
# =============================================================================
# JWT secret for session tokens
# IMPORTANT: Must be at least 32 characters long
# Generate a secure secret using one of these methods:
#   - Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   - OpenSSL: openssl rand -hex 32
#   - Or run: pnpm generate-secret (if available)
# DO NOT use the placeholder value in production.
JWT_SECRET=your-random-secret-key-here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Application ID used by the client runtime
VITE_APP_ID=

# Port to run the server on (default: 3000)
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# =============================================================================
# OAUTH CONFIGURATION
# =============================================================================
# Google OAuth credentials
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Owner Open ID (optional - bootstrap admin access)
OWNER_OPEN_ID=

# Master admin email allowed to manage other admins
MASTER_ADMIN_EMAIL=

# =============================================================================
# AI API KEYS
# =============================================================================
# Manus API key used for development mode and advanced AI workflows
MANUS_API=

# Perplexity API key for external research workflows
PERPLEXITY_API=

# OpenAI API key for optional multi-model integrations
OPENAI_API_KEY=

# Anthropic API key for optional multi-model integrations
ANTHROPIC_API_KEY=

# Z.ai / GLM API key for optional model usage
ZAI_API_KEY=

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================
# Cloudinary URL used for avatars, call recordings, transcript exports, and other artifacts
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=

# =============================================================================
# EMAIL / SMTP CONFIGURATION
# =============================================================================
# SMTP host used for OTP and outbound notification emails
SMTP_HOST=

# SMTP outgoing port (commonly 465 for SSL/TLS or 587 for STARTTLS)
SMTP_PORT_OUTGOING=465

# SMTP username / mailbox
SMTP_USER=

# SMTP password
SMTP_PASS=

# Optional custom from address. Defaults to SMTP_USER when blank.
SMTP_FROM=

# =============================================================================
# VOICE ASSISTANT / COMMUNICATIONS INTEGRATION
# =============================================================================
# Twilio API key SID (not the account SID) used for programmable voice actions
TWILIO_SID=

# Twilio API key secret paired with TWILIO_SID
TWILIO_SECRET=

# Twilio auth token used for webhook validation and call operations
TWILIO_AUTH_TOKEN=

# Twilio phone number used for outbound and inbound voice assistant calls
TWILIO_PHONE_NUMBER=

# ElevenLabs API key used for voice agent management and transcript retrieval
ELEVENLABS_API_KEY=

# Default ElevenLabs conversational agent ID for voice assistant orchestration
ELEVENLABS_AGENT_ID=

# Secret used to validate ElevenLabs webhook payloads
ELEVENLABS_AGENT_WEBHOOK_SECRET=

# Optional comma-separated ElevenLabs voice IDs exposed in the admin UI as selectable voices
# Example: 21m00Tcm4TlvDq8ikWAM,EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_IDS=

# Enable ElevenLabs V3 emotions by default for newly created agents (true/false)
ELEVENLABS_DEFAULT_EMOTIONS=true

# Zoom server-to-server OAuth account ID
ZOOM_ACCOUNT_ID=

# Zoom OAuth client ID
ZOOM_CLIENT_ID=

# Zoom OAuth client secret
ZOOM_CLIENT_SECRET=

# Zoom webhook secret token used to verify event notifications
ZOOM_SECRET_TOKEN=

# Public webhook URL configured in the Zoom marketplace app
ZOOM_EVENT_WEBHOOK=

# Experimental Pika API key for AI avatar/video dial-in during live meetings
PIKA_API_KEY=

# =============================================================================
# OPTIONAL INTERNAL / PLATFORM OVERRIDES
# =============================================================================
# Built-in forge service URL and API key used by internal tooling, if enabled
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
