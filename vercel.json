{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "rm -rf dist .vercel/output && pnpm run build:vercel",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "crons": [
    {
      "path": "/api/cron/voice-scheduler",
      "schedule": "* * * * *"
    }
  ]
}
